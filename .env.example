# ============================================================
#  .env.example — Configurações Globais do Sistema de EPI
#  Instruções: Copie este arquivo para .env e preencha os dados.
#  IMPORTANTE: O arquivo .env real NÃO deve ser enviado ao Git.
# ============================================================

# ── 1. Câmera e Captura ──────────────────────────────────────
# ID da câmera principal para testes rápidos (0 = Webcam)
CAMERA_INDEX=0

# Resolução de processamento (640x480 é o ideal para o Raspberry Pi 5)
FRAME_WIDTH=640
FRAME_HEIGHT=480

# ── 2. Inteligência Artificial (YOLOv8) ──────────────────────
# Caminho do modelo (ex: yolov8n.pt ou seu_modelo_treinado.pt)
MODEL_PATH=yolov8n.pt

# Limiar de confiança (0.55 é recomendado para evitar falsos alertas)
CONFIDENCE=0.55
IOU_THRESH=0.45

# IDs das Classes (Verifique no seu arquivo dataset.yaml)
PERSON_ID=0
HELMET_ID=1
VEST_ID=2
BOOT_ID=3

# ── 3. Regras de Segurança (Engenharia de Prompt) ────────────
# Defina quais EPIs o sistema deve exigir para dar o status "OK"
REQUIRE_HELMET=true
REQUIRE_VEST=true
REQUIRE_BOOT=true

# ── 4. Sistema de Alertas SMTP (Monitoramento Industrial) ────
# Configuração para envio de e-mail com foto da infração
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=seu_email_alerta@gmail.com
EMAIL_PASS=sua_senha_de_app_de_16_digitos
EMAIL_DEST=supervisor_seguranca@empresa.com.br

# Tempo de silêncio (Cooldown) em segundos entre alertas da mesma câmera
# 300 segundos = 5 minutos (Evita inundar a caixa de entrada)
ALERT_COOLDOWN=300

# ── 5. Alertas Secundários (Telegram) ────────────────────────
TELEGRAM_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# ── 6. Operação e Interface ──────────────────────────────────
# Mude para 'false' quando rodar no Raspberry Pi na fábrica (Modo Headless)
SHOW_VIDEO=true
SAVE_FRAMES=true