# ============================================================
#  .env.example — Copie para .env e preencha os valores
#  NÃO commite o arquivo .env no Git!
# ============================================================

# ── Câmera ───────────────────────────────────────────────────
#
# OPÇÃO 1 - WEBCAM/USB (usar índice numérico):
#   0 = webcam integrada / primeira câmera
#   1 = câmera USB / segunda câmera  
#   2 = terceira câmera...
#
# OPÇÃO 2 - CÂMERA IP (usar URL RTSP/HTTP):
#
#   INTELBRAS (modelos VIP, IP, etc):
#     rtsp://admin:senha@192.168.1.108:554/cam/realmonitor?channel=1&subtype=0
#     rtsp://usuario:senha@IP:554/cam/realmonitor?channel=1&subtype=0
#
#   HIKVISION:
#     rtsp://admin:senha@192.168.1.64:554/Streaming/Channels/101
#
#   DAHUA:
#     rtsp://admin:senha@192.168.1.108:554/cam/realmonitor?channel=1&subtype=0
#
#   GENÉRICA (ONVIF):
#     rtsp://usuario:senha@IP:554/stream1
#     rtsp://usuario:senha@IP:554/live/main
#
#   MJPEG/HTTP:
#     http://192.168.1.108/video.mjpg
#     http://usuario:senha@192.168.1.108/video.mjpg
#
# DICAS:
#   - Teste a URL no VLC antes: Mídia > Abrir Fluxo de Rede
#   - Porta padrão RTSP: 554
#   - Verifique firewall e rede
#   - Use IP fixo na câmera para evitar problemas
#
# EXEMPLOS:
#   CAMERA_INDEX=0                                                    # webcam
#   CAMERA_INDEX=rtsp://admin:12345@192.168.1.108:554/cam/realmonitor?channel=1&subtype=0
#   CAMERA_INDEX=http://192.168.1.108:8080/video.mjpg
#
CAMERA_INDEX=0

# Resolução do frame (largura x altura)
# Valores comuns: 640x480, 1280x720, 1920x1080
# Menor resolução = mais FPS, maior = melhor qualidade
FRAME_WIDTH=640
FRAME_HEIGHT=480

# ── Modelo YOLOv8 ────────────────────────────────────────────
# yolov8n.pt → nano (mais rápido, menos preciso) — ideal para MVP
# yolov8s.pt → small (equilíbrio velocidade/precisão)
# yolov8m.pt → medium (mais preciso, mais lento)
# custom.pt  → modelo treinado em dataset de EPI
#
# Downloads de modelos PPE:
#   https://universe.roboflow.com/roboflow-universe-projects/construction-site-safety
#   https://universe.roboflow.com/personal-project-dataset/ppe-safety
#
MODEL_PATH=yolov8n.pt

# Limiar de confiança (0.0 a 1.0)
# Valor menor = mais detecções (mais falsos positivos)
# Valor maior = menos detecções (mais falsos negativos)
# Recomendado: 0.40-0.50
CONFIDENCE=0.45

# IoU threshold para NMS (Non-Maximum Suppression)
# Remove detecções duplicadas/sobrepostas
IOU_THRESH=0.45

# ── Modo Demo ────────────────────────────────────────────────
# true  = usa modelo COCO (detecta apenas "person") — para testes
# false = usa modelo PPE customizado com helmet/vest
DEMO_MODE=true

# ── Regras EPI ────────────────────────────────────────────────
# Fração da bbox da pessoa para região da cabeça (0.0 a 1.0)
# 0.30 = 30% superior da pessoa é considerado "cabeça"
HEAD_REGION_RATIO=0.30

# IoU mínimo capacete↔cabeça para associação (0.0 a 1.0)
# Valor menor = mais permissivo, maior = mais restritivo
HELMET_IOU_THRESHOLD=0.15

# EPIs obrigatórios (true/false)
REQUIRE_HELMET=true
REQUIRE_VEST=false

# ── Alertas Telegram ─────────────────────────────────────────
# Como configurar:
# 1. Abra @BotFather no Telegram → /newbot → copie o TOKEN
# 2. Inicie uma conversa com o bot
# 3. Acesse: https://api.telegram.org/bot<TOKEN>/getUpdates
#    e copie o "id" do chat
TELEGRAM_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# Intervalo mínimo entre alertas do mesmo tipo (segundos)
ALERT_COOLDOWN=30

# ── Dashboard ────────────────────────────────────────────────
DASHBOARD_PORT=8501

# ── Exibição ─────────────────────────────────────────────────
# false = útil em servidores sem interface gráfica (Raspberry Pi headless)
SHOW_VIDEO=true
